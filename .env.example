# =============================================================================
# Anuncio Link — variáveis de ambiente (exemplo)
# =============================================================================
# 1. Copie este arquivo:  cp .env.example .env.local
# 2. Preencha os valores reais APENAS no .env.local (nunca commite .env.local)
# 3. No deploy (Vercel/Netlify), configure as mesmas chaves no painel do host
# =============================================================================

# Google AdSense (opcional — deixe vazio para exibir placeholders na UI)
# Obtenha em: https://www.google.com/adsense/
VITE_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_SLOT_TOP=
VITE_ADSENSE_SLOT_MID=
VITE_ADSENSE_SLOT_FOOT=

# URL pública do site (referência para deploy — o app usa www.anunciolink.com.br por padrão)
# APP_URL=https://www.anunciolink.com.br
